{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:app:allow-set-app-theme",
    "store:default",
    "agodesk-commands",
    {
      "identifier": "core:event:allow-listen",
      "allow": [
        "agodesk:connection-state",
        "agodesk:message",
        "agodesk:error"
      ]
    }
  ]
}
