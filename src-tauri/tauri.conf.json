{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "agodesk",
  "version": "0.1.0",
  "identifier": "com.agodesk.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "agodesk",
        "label": "main",
        "width": 900,
        "height": 700,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: https: http:; connect-src 'self' ws: wss: http: https: ipc: http://ipc.localhost; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval'; worker-src 'self' blob:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "bin/agodesk-worker",
      "bin/agodesk-speech"
    ],
    "resources": {
      "bin/*.dll": "./"
    },
    "windows": {
      "nsis": {
        "installMode": "both",
        "languages": [
          "English",
          "German",
          "French",
          "Spanish",
          "SimpChinese",
          "Japanese",
          "Dutch",
          "Portuguese",
          "Italian",
          "Swedish"
        ],
        "displayLanguageSelector": false,
        "compression": "lzma",
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "installerHooks": "installer.nsh"
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1",
          "librsvg2-2"
        ],
        "postInstallScript": "postinst.sh",
        "postRemoveScript": "postrm.sh"
      },
      "rpm": {
        "depends": [
          "webkit2gtk4.1",
          "gtk3",
          "libayatana-appindicator-gtk3",
          "librsvg2"
        ],
        "postInstallScript": "postinst.sh",
        "postRemoveScript": "postrm.sh",
        "release": "1"
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
