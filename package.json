{
  "name": "agodesk",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "tauri": "tauri",
    "mock-server": "node scripts/mock-server.mjs",
    "build:sidecar": "node scripts/copy-sidecar.mjs --ensure-dummy && cd src-tauri && cargo build --release --bin agodesk-worker --features computer-use-sidecar && cd .. && node scripts/copy-sidecar.mjs",
    "build:win": "npm run build && npm run build:sidecar && npm run tauri -- build --bundles nsis --features computer-use-sidecar",
    "build:win-installer": "npm run build:win",
    "test": "node --import tsx --test src/lib/**/*.test.ts"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-store": "^2"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tsx": "^4.19.4",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "ws": "^8.21.0"
  }
}
